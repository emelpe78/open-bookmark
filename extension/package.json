{
  "name": "open-bookmark-extension",
  "private": true,
  "version": "1.0.2",
  "description": "Chrome-Extension (MV3) zum Speichern von Seiten in der lokalen Open-Bookmark-Instanz",
  "author": "Marc Lettau-Poelchen (https://github.com/emelpe78)",
  "license": "MIT",
  "homepage": "https://github.com/emelpe78/open-bookmark/tree/main/extension#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emelpe78/open-bookmark.git",
    "directory": "extension"
  },
  "bugs": {
    "url": "https://github.com/emelpe78/open-bookmark/issues"
  },
  "keywords": [
    "chrome-extension",
    "bookmarks",
    "manifest-v3",
    "open-bookmark"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "icons": "bash scripts/generate-icons.sh",
    "prebuild": "npm run icons",
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tag-utils": "file:../packages/tag-utils"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.31",
    "@types/chrome": "^0.0.320",
    "sharp": "^0.34.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
