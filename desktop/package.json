{
  "name": "open-bookmark-desktop",
  "private": true,
  "version": "1.0.1",
  "description": "Open Bookmark — native macOS-Desktop-App (Electron-Hülle für die lokale Nitro-Runtime)",
  "author": "Marc Lettau-Poelchen (https://github.com/emelpe78)",
  "license": "MIT",
  "homepage": "https://github.com/emelpe78/open-bookmark/tree/main/desktop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emelpe78/open-bookmark.git",
    "directory": "desktop"
  },
  "bugs": {
    "url": "https://github.com/emelpe78/open-bookmark/issues"
  },
  "keywords": [
    "electron",
    "macos",
    "bookmarks",
    "open-bookmark",
    "desktop-app"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cp src/preload.cjs dist/preload.cjs",
    "dev": "npm run icons && bash scripts/patch-electron-mac.sh && npm run build && bash scripts/run-dev.sh",
    "start": "bash scripts/run-dev.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "icons": "bash scripts/generate-icons.sh",
    "prepare-node": "bash scripts/prepare-node.sh",
    "build:runtime": "bash scripts/build-runtime.sh",
    "prepack": "npm run icons",
    "pack": "npm run pack:release",
    "pack:dir": "npm run build:runtime && npm run build && electron-builder --mac dir",
    "pack:release": "npm run build:runtime && npm run build && electron-builder --mac dir && bash scripts/codesign-mac-app.sh && electron-builder --mac dmg --prepackaged \"release/mac-arm64/Open Bookmark.app\"",
    "postinstall": "npm run icons && bash scripts/patch-electron-mac.sh"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "sharp": "^0.34.2",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "app.openbookmark.desktop",
    "productName": "Open Bookmark",
    "publish": null,
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/preload.cjs",
      "src/error.html",
      "package.json",
      "resources/icon.png",
      "resources/icon.icns",
      "resources/about.html"
    ],
    "extraResources": [
      {
        "from": "../open-bookmark/.output",
        "to": "open-bookmark/.output"
      },
      {
        "from": "../open-bookmark/node_modules",
        "to": "open-bookmark/node_modules"
      },
      {
        "from": "../open-bookmark/package.json",
        "to": "open-bookmark/package.json"
      },
      {
        "from": "../extension/dist",
        "to": "extension-dist"
      },
      {
        "from": "resources/node",
        "to": "node"
      }
    ],
    "mac": {
      "icon": "icon.icns",
      "identity": null,
      "gatekeeperAssess": false,
      "target": [
        "dir"
      ],
      "category": "public.app-category.productivity",
      "extendInfo": {
        "CFBundleDisplayName": "Open Bookmark",
        "CFBundleName": "Open Bookmark"
      }
    }
  }
}
