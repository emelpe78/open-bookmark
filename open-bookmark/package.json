{
  "name": "open-bookmark",
  "version": "1.0.2",
  "private": true,
  "description": "Local-first Bookmark-Manager — Nuxt-4-Oberfläche und Nitro-API mit SQLite",
  "author": "Marc Lettau-Poelchen (https://github.com/emelpe78)",
  "license": "MIT",
  "homepage": "https://github.com/emelpe78/open-bookmark#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emelpe78/open-bookmark.git",
    "directory": "open-bookmark"
  },
  "bugs": {
    "url": "https://github.com/emelpe78/open-bookmark/issues"
  },
  "keywords": [
    "bookmarks",
    "local-first",
    "nuxt",
    "nitro",
    "sqlite",
    "markdown"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3777",
    "generate": "nuxt generate",
    "preview": "nuxt preview --port 3777",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt prepare && vue-tsc -p .nuxt/tsconfig.app.json --noEmit && vue-tsc -p .nuxt/tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "tag-utils": "file:../packages/tag-utils",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/ui": "^4.1.0",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.1.0",
    "isomorphic-dompurify": "^2.25.0",
    "marked": "^15.0.12",
    "marked-footnote": "^1.4.0",
    "nuxt": "^4.1.3",
    "tailwindcss": "^4.1.8",
    "vue": "^3.5.13",
    "vue-router": "^5.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.108",
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  }
}
